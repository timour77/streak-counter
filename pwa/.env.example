# Copy this file to .env for local development (`cp .env.example .env`) and fill in real values.
# In production, set these in the Vercel project settings / `vercel env add` instead.

# Generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

PORT=3000

# Free key at https://developers.giphy.com/dashboard/. Leave empty to skip GIFs
# (streak completion still shows confetti).
GIPHY_API_KEY=
GIPHY_RATING=g

# Required in production to stop random people from hitting /api/cron and
# spamming your notifications. Any random string of 16+ characters works.
# Not needed locally.
CRON_SECRET=

# Injected automatically by the Upstash Redis integration once you run
# `vercel install upstash` (or add it from the Vercel dashboard) and then
# `vercel env pull`. Not needed locally — without it, data/store.json is used instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
