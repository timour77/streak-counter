# Copy this file to .env for local development (`cp .env.example .env`) and fill in real values.
# In production, set these in the Vercel project settings / `vercel env add` instead.

# Generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

PORT=3000

# Free key at https://developers.giphy.com/dashboard/. Leave empty to skip GIFs
# (streak completion still shows confetti).
GIPHY_API_KEY=
GIPHY_RATING=g

# Required in production to stop random people from hitting /api/cron and
# spamming your notifications. Any random string of 16+ characters works.
# Not needed locally.
CRON_SECRET=

# Injected automatically by the "Upstash for Redis" Vercel Marketplace integration
# (`vercel install upstash/upstash-kv`) into .env.local — copy KV_REST_API_URL and
# KV_REST_API_TOKEN from there if you want to test against real Redis locally too.
# Not required locally — without it, data/store.json is used instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Injected automatically by the Clerk Vercel Marketplace integration
# (`vercel install clerk`) into .env.local. Not required locally — without it,
# every request is treated as a single fixed "local-dev-user" (no sign-in needed).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
